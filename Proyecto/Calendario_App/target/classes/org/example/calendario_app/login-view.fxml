<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Text?>

<HBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" stylesheets="@login.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.calendario_app.AppController">
   <children>
      <VBox alignment="CENTER_LEFT" prefHeight="600.0" prefWidth="450.0" styleClass="left-pane" HBox.hgrow="ALWAYS">
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
         <children>
            <Label styleClass="title-label" text="Organiza tu vida, sin esfuerzo" wrapText="true" />
            <Label styleClass="subtitle-label" text="Tu calendario personal para compartir horarios y coordinar actividades sin complicaciones." wrapText="true">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Label>
            <StackPane prefHeight="250.0" prefWidth="200.0" styleClass="image-placeholder">
               <VBox.margin>
                  <Insets top="40.0" />
               </VBox.margin>
               <children>
                  <ImageView fitHeight="200.0" fitWidth="300.0" pickOnBounds="true" preserveRatio="true" />
               </children>
            </StackPane>
         </children>
      </VBox>

      <VBox alignment="CENTER_LEFT" prefHeight="600.0" prefWidth="450.0" styleClass="right-pane" HBox.hgrow="ALWAYS">
         <padding>
            <Insets bottom="40.0" left="60.0" right="60.0" top="40.0" />
         </padding>
         <children>
            <Label fx:id="lblHeader" styleClass="header-label" text="Accede a tu cuenta" />

            <HBox alignment="CENTER" styleClass="toggle-container">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
               <children>
                  <Button fx:id="btnToggleLogin" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onToggleLogin" styleClass="toggle-button, active" text="Iniciar Sesión" HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnToggleRegister" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onToggleRegister" styleClass="toggle-button" text="Registro" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>

            <VBox fx:id="registerFieldsContainer" managed="false" visible="false">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
               <children>
                  <Label styleClass="field-label" text="Nombre" />
                  <TextField fx:id="txtName" promptText="Tu nombre" styleClass="input-field">
                     <VBox.margin>
                        <Insets top="5.0" />
                     </VBox.margin>
                  </TextField>
                  
                  <Label styleClass="field-label" text="Apellidos">
                     <VBox.margin>
                        <Insets top="15.0" />
                     </VBox.margin>
                  </Label>
                  <TextField fx:id="txtSurname" promptText="Tus apellidos" styleClass="input-field">
                     <VBox.margin>
                        <Insets top="5.0" />
                     </VBox.margin>
                  </TextField>
               </children>
            </VBox>

            <Label styleClass="field-label" text="Correo Electrónico">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Label>
            <TextField fx:id="txtEmail" promptText="tu@email.com" styleClass="input-field">
               <VBox.margin>
                  <Insets top="5.0" />
               </VBox.margin>
            </TextField>
            

            <Label styleClass="field-label" text="Contraseña">
               <VBox.margin>
                  <Insets top="15.0" />
               </VBox.margin>
            </Label>
            <StackPane alignment="CENTER_RIGHT">
               <VBox.margin>
                  <Insets top="5.0" />
               </VBox.margin>
               <children>
                  <PasswordField fx:id="txtPassword"  promptText="Introduce tu contraseña" styleClass="input-field" />
                  <TextField fx:id="txtPasswordVisible" managed="false" promptText="Introduce tu contraseña" styleClass="input-field" visible="false" />
                  <Button fx:id="btnShowPassword" mnemonicParsing="false" onAction="#onTogglePasswordVisibility" styleClass="icon-button" text="👁">
                     <StackPane.margin>
                        <Insets right="10.0" />
                     </StackPane.margin>
                  </Button>
               </children>
            </StackPane>
            
            <HBox fx:id="boxForgotPassword" alignment="CENTER_RIGHT">
               <children>
                  <Label styleClass="link-label" text="¿Olvidé mi contraseña?" />
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </HBox>
            

            <Button fx:id="btnLogin" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="primary-button" text="Iniciar Sesión" onAction="#onLoginButtonClick">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Button>
            

            <HBox alignment="CENTER" spacing="10.0">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
               <children>
                  <Line endX="100.0" styleClass="separator-line" />
                  <Text fill="#8a8a8a" strokeType="OUTSIDE" strokeWidth="0.0" text="o" />
                  <Line endX="100.0" styleClass="separator-line" />
               </children>
            </HBox>
            

            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="secondary-button" text="G  Continuar con Google">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Button>
            
            <HBox alignment="CENTER" spacing="5.0">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
               <children>
                  <Text fill="#b0b0b0" strokeType="OUTSIDE" strokeWidth="0.0" text="¿No tienes una cuenta?" />
                  <Label styleClass="link-label-bold" text="Regístrate gratis" />
               </children>
            </HBox>
            
         </children>
      </VBox>
   </children>
</HBox>
